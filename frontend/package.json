{
  "name": "doc-assistant-frontend",
  "version": "0.1.0",
  "description": "智能文档助手前端 (Vue 3 + Vite + Tailwind)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.2.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@vueuse/core": "^10.7.0",
    "axios": "^1.6.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.0.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^13.0.7",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
