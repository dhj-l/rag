# =============================================================================
# 智能文档助手 — 环境变量模板
# 复制为 .env 并填写真实值；.env 不入版本控制。参考架构 §7.4
# =============================================================================

# ---- 后端服务 ----
PORT=3000

# ---- MongoDB ----
MONGODB_URI=mongodb://root:rootpass@localhost:27017/doc_assistant?authSource=admin
# Docker Compose 中 MongoDB 初始化账号（仅 mongo 容器使用）
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpass

# ---- Chroma 向量库 ----
CHROMA_URL=http://localhost:8000

# ---- LLM（DeepSeek）----
# T03 才真正调用；T01 阶段可留空
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat

# ---- Embedding（硅基流动 SiliconFlow）----
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# ---- JWT（认证，T02 接入）----
# 必填：生产环境务必替换为强随机字符串
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=24h

# ---- 文件上传 ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=20971520

# ---- Langfuse 追踪（T03 接入）----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=http://localhost:3001

# ---- PostgreSQL / Langfuse（Docker Compose 用）----
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse
POSTGRES_DB=langfuse
NEXTAUTH_SECRET=change-me-in-prod
SALT=change-me-in-prod
